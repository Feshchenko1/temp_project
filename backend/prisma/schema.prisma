generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(uuid())
  fullName         String
  email            String          @unique
  password         String
  bio              String?         @default("")
  profilePic       String?         @default("")
  isOnboarded      Boolean         @default(false)
  instrumentsKnown   String[]
  instrumentsToLearn String[]
  spokenLanguages    String[]
  location         String?         @default("")
  publicKey        String?         @db.Text
  encryptedPrivateKey String?      @db.Text
  cryptoSalt        String?        @db.Text
  recoveryEncryptedKey String?     @db.Text
  recoverySalt         String?     @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  friends          User[]          @relation("UserFriends")
  friendOf         User[]          @relation("UserFriends")
  
  sentRequests     FriendRequest[] @relation("SenderRequests")
  receivedRequests FriendRequest[] @relation("RecipientRequests")
  

  messages         Message[]
  
  sentGroupKeys    GroupKey[]      @relation("GroupKeySender")
  receivedGroupKeys GroupKey[]     @relation("GroupKeyRecipient")

  chatMembers      ChatMember[]
  scores           Score[]         @relation("UserScores")
  favoriteScores   FavoriteScore[] @relation("UserFavorites")
  tracks           Track[]         @relation("UserTracks")
  playlists        Playlist[]      @relation("UserPlaylists")
}

model FriendRequest {
  id         String   @id @default(uuid())
  senderId   String
  recipientId String
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender    User @relation("SenderRequests", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User @relation("RecipientRequests", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([senderId, recipientId])
}

model Chat {
  id           String   @id @default(uuid())
  isGroup      Boolean  @default(false)
  chatType     ChatType @default(PERMANENT)
  name         String?
  groupImage   String?
  activeCallId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members   ChatMember[]
  messages  Message[]
  groupKeys GroupKey[]
}

model ChatMember {
  chatId    String
  userId    String
  role      MemberRole @default(MEMBER)
  isMuted   Boolean    @default(false)
  isPinnedToNavbar Boolean @default(false)
  joinedAt  DateTime   @default(now())

  chat      Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([chatId, userId])
}

enum ChatType {
  PERMANENT
  EPHEMERAL
}

enum MemberRole {
  ADMIN
  MEMBER
}

model Message {
  id        String   @id @default(uuid())
  content   String?
  fileUrl   String?
  fileType  String?
  originalName String?
  isPinned  Boolean  @default(false)
  status    String   @default("SENT")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  senderId  String
  chatId    String
  replyToId String?

  sender    User      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  chat      Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  replyTo   Message?  @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   Message[] @relation("MessageReplies")
}


model Instrument {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Track {
  id        String   @id @default(uuid())
  title     String
  artist    String
  fileUrl   String
  coverUrl  String?
  duration  Int?     @default(0) // NEW: Duration in seconds
  userId    String
  user      User     @relation("UserTracks", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  playlistTracks PlaylistTrack[]
}

model Playlist {
  id          String   @id @default(uuid())
  title       String
  description String?
  coverUrl    String?
  userId      String
  user        User     @relation("UserPlaylists", fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tracks      PlaylistTrack[]
}

model PlaylistTrack {
  id         String   @id @default(uuid())
  playlistId String
  trackId    String
  addedAt    DateTime @default(now())

  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([playlistId, trackId])
}

model Score {
  id          String   @id @default(uuid())
  title       String
  artist      String?
  fileUrl     String
  audioUrl    String?
  fileSize    Int?
  pagesCount  Int?
  userId      String
  user        User     @relation("UserScores", fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  tags        ScoreTagMapping[]
  favoritedBy FavoriteScore[]
}

model ScoreTag {
  id    String @id @default(uuid())
  name  String @unique
  scores ScoreTagMapping[]
}

model ScoreTagMapping {
  scoreId String
  tagId   String
  score   Score    @relation(fields: [scoreId], references: [id], onDelete: Cascade)
  tag     ScoreTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@id([scoreId, tagId])
}

model FavoriteScore {
  userId  String
  scoreId String
  user    User  @relation("UserFavorites", fields: [userId], references: [id], onDelete: Cascade)
  score   Score @relation(fields: [scoreId], references: [id], onDelete: Cascade)
  
  @@id([userId, scoreId])
}

model GroupKey {
  id              String   @id @default(uuid())
  chatId          String
  senderId        String
  recipientId     String
  encryptedAesKey String   @db.Text
  createdAt       DateTime @default(now())

  chat      Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User   @relation("GroupKeySender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User   @relation("GroupKeyRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([chatId, senderId, recipientId])
}

model VerificationToken {
  id        String   @id @default(uuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
